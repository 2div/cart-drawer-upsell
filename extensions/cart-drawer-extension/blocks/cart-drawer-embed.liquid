<div
  class="cdu-cart-drawer"
  data-cdu-cart-drawer
  data-cdu-show-shipping-progress="{{ block.settings.show_shipping_progress }}"
  data-cdu-shipping-goal="{{ block.settings.shipping_goal }}"
  data-cdu-shipping-message="{{ block.settings.shipping_message | escape }}"
  data-cdu-shipping-success-message="{{ block.settings.shipping_success_message | escape }}"
  data-cdu-replace-native-drawer="{{ block.settings.replace_native_drawer }}"
  style="
    --cdu-background: {{ block.settings.background_color }};
    --cdu-text: {{ block.settings.text_color }};
  "
>
  <button
    type="button"
    class="cdu-cart-drawer__launcher"
    data-cdu-open
    aria-controls="cdu-cart-panel-{{ block.id }}"
    aria-expanded="false"
    tabindex="-1"
    hidden
  >
    {{ block.settings.launcher_label }}
  </button>

  <div
    class="cdu-cart-drawer__overlay"
    data-cdu-overlay
  ></div>

  <aside
    id="cdu-cart-panel-{{ block.id }}"
    class="cdu-cart-drawer__panel"
    data-cdu-panel
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-labelledby="cdu-cart-title-{{ block.id }}"
  >
    <header class="cdu-cart-drawer__header">
      <h2 id="cdu-cart-title-{{ block.id }}">
        {{ block.settings.heading }}
      </h2>

      <button
        type="button"
        class="cdu-cart-drawer__close"
        data-cdu-close
        aria-label="Close cart drawer"
      >
        &times;
      </button>
    </header>

    <div
      class="cdu-shipping-progress"
      data-cdu-shipping-progress
      hidden
    >
      <p
        class="cdu-shipping-progress__message"
        data-cdu-shipping-message
      ></p>

      <div
        class="cdu-shipping-progress__track"
        role="progressbar"
        aria-label="Free shipping progress"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="0"
        data-cdu-shipping-track
      >
        <span
          class="cdu-shipping-progress__bar"
          data-cdu-shipping-bar
        ></span>
      </div>
    </div>

    <div
      class="cdu-cart-drawer__content"
      data-cdu-content
    >
      <p class="cdu-cart-drawer__loading">
        Loading cart...
      </p>
    </div>

    <p
      class="cdu-visually-hidden"
      data-cdu-status
      role="status"
      aria-live="polite"
    ></p>

    <footer
      class="cdu-cart-drawer__footer"
      data-cdu-footer
      hidden
    >
      <div class="cdu-cart-drawer__subtotal">
        <span>Subtotal</span>
        <strong data-cdu-subtotal></strong>
      </div>

      <a
        class="cdu-cart-drawer__checkout"
        href="/checkout"
      >
        Check out
      </a>
    </footer>
  </aside>
</div>

{% schema %}
{
  "name": "Cart Drawer",
  "target": "body",
  "stylesheet": "cart-drawer.css",
  "javascript": "cart-drawer.js",
  "settings": [
    {
      "type": "checkbox",
      "id": "replace_native_drawer",
      "label": "Replace the theme cart drawer",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Drawer heading",
      "default": "Your cart"
    },
    {
      "type": "text",
      "id": "launcher_label",
      "label": "Test button label",
      "default": "Open cart"
    },
    {
      "type": "checkbox",
      "id": "show_shipping_progress",
      "label": "Show free shipping progress",
      "default": true
    },
    {
      "type": "number",
      "id": "shipping_goal",
      "label": "Free shipping goal",
      "default": 100
    },
    {
      "type": "text",
      "id": "shipping_message",
      "label": "Progress message",
      "default": "You are [amount] away from free shipping"
    },
    {
      "type": "text",
      "id": "shipping_success_message",
      "label": "Success message",
      "default": "You have unlocked free shipping!"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    }
  ]
}
{% endschema %}